# Set default behavior to automatically normalize line endings
* text=auto eol=lf

# GitHub Actions workflow files
*.yml text eol=lf
*.yaml text eol=lf

# TypeScript/JavaScript files for actions
*.js text eol=lf
*.ts text eol=lf
*.json text eol=lf

# Documentation
*.md text eol=lf

# Shell scripts
*.sh text eol=lf
